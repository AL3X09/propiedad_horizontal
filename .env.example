# ============================================================
# APLICACIÓN
# ============================================================
APP_NAME="Backend Propiedad Horizontal"
APP_HOST=0.0.0.0
APP_PORT=8001
ENVIRONMENT=production

# ============================================================
# BASE DE DATOS — PostgreSQL + Tortoise ORM
# Formato: postgres://usuario:contraseña@host:puerto/nombre_bd
# En Podman usar el nombre del contenedor, NO localhost
# ============================================================
DATABASE_URL=postgres://usuario:contraseña@nombre-contenedor-postgres:5432/nombre_bd

# ============================================================
# JWT
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
JWT_SECRET_KEY=CAMBIAR_POR_CLAVE_SEGURA_DE_64_CARACTERES
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ============================================================
# SERVICIO DE NOTIFICACIONES
# Usar nombre del contenedor en la red de Podman, NO localhost
# ============================================================
NOTIFICACIONES_SERVICE_URL=http://nombre-contenedor-notificaciones:8082
NOTIFICACIONES_API_KEY=CAMBIAR_POR_API_KEY_REAL

# ============================================================
# CORS
# En producción usar solo el dominio real
# ============================================================
CORS_ORIGINS='["https://midominio.com"]'
