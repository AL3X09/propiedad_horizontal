# ============================================================
# APLICACIÓN
# ============================================================
APP_NAME="Backend Propiedad Horizontal"
APP_HOST=0.0.0.0
APP_PORT=8001
ENVIRONMENT=production

# ============================================================
# BASE DE DATOS — PostgreSQL
# Usa el nombre del contenedor/pod postgres en ph-network,
# NO uses localhost ni la IP del host
# ============================================================
DATABASE_URL=postgresql+asyncpg://PruebasQA:PruebasQA*@db-pod:5432/PropiedadHorizontalDB

# Por separado (algunos módulos FastAPI los leen individualmente)
DB_HOST=db-pod
DB_PORT=5432
DB_NAME=PropiedadHorizontalDB
DB_USER=PruebasQA
DB_PASSWORD=PruebasQA*

# ============================================================
# SEGURIDAD / JWT
# Genera la clave con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
JWT_SECRET_KEY=5301b7c6c6946658293d1dab41fd5af1174c79705959ad4f0c96d946f2b49400
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ============================================================
# SERVICIO DE NOTIFICACIONES
# ⚠️  "localhost" NO funciona en Podman — usar nombre del contenedor
#     que está en ph-network y expone el 8082
# ============================================================
NOTIFICACIONES_SERVICE_URL=http://notificaciones-pod:8082
NOTIFICACIONES_API_KEY=pSDcWK9FrcZ-vJ3t4PvanLqmQ_muqdAE0YL_PUgQcCk

# ============================================================
# CORS
# En producción elimina los localhost; deja solo tu dominio real
# En desarrollo puedes tener ambos
# ============================================================
CORS_ORIGINS='["http://localhost","http://localhost:8080","http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173","https://midominio.com"]'
